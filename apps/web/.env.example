# Accounts
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_PIMLICO_API_KEY=

# Blockchain RPC (Mainnet)
NEXT_PUBLIC_GEOGENESIS_RPC=
NEXT_PUBLIC_API_ENDPOINT=
NEXT_PUBLIC_BUNDLER_RPC=

# Blockchain RPC (Testnet)
NEXT_PUBLIC_GEOGENESIS_RPC_TESTNET=
NEXT_PUBLIC_API_ENDPOINT_TESTNET=
NEXT_PUBLIC_BUNDLER_RPC_TESTNET=

# Onboarding
NEXT_PUBLIC_ONBOARD_FLAG=
NEXT_PUBLIC_ONBOARD_CODE=

# Sentry (optional)
# NEXT_PUBLIC_APP_ENV=                    # Deployment environment (default: "development")
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=                             # All 3 required together for source maps
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Features (optional)
# NEXT_PUBLIC_MAPBOX_TOKEN=

# Governance red-dot via gaia notification-service (optional)
# When enabled, the browse sidebar polls /api/pending-votes (Redis-backed, driven
# by webhooks from gaia) instead of rescanning all editor spaces each tick.
# Requires UPSTASH_REDIS_REST_URL/TOKEN to be set and the webhook URL registered
# in gaia's app_webhooks table with the matching secret.
# NEXT_PUBLIC_USE_NOTIFICATION_SERVICE=true
# GEO_NOTIFICATIONS_WEBHOOK_SECRET=         # HMAC-SHA256 shared secret; generate with `openssl rand -hex 32`

# Build (optional)
# DISABLE_REACT_COMPILER=1
# DISABLE_SENTRY=1

# Dev (optional)
# NEXT_PUBLIC_ENGINE_LOGGING=0            # Set to 0 to suppress
# NEXT_PUBLIC_STORE_LOGGING=0             # Set to 0 to suppress
