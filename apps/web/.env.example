# Accounts
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_PIMLICO_API_KEY=

# Blockchain RPC (Mainnet)
NEXT_PUBLIC_GEOGENESIS_RPC=
NEXT_PUBLIC_API_ENDPOINT=
NEXT_PUBLIC_BUNDLER_RPC=

# Blockchain RPC (Testnet)
NEXT_PUBLIC_GEOGENESIS_RPC_TESTNET=
NEXT_PUBLIC_API_ENDPOINT_TESTNET=
# Optional since geo-sdk beta.8 (SDK ships the sponsorship endpoint); local-anvil override only
NEXT_PUBLIC_ZERODEV_RPC_URL_TESTNET=

# Onboarding
NEXT_PUBLIC_ONBOARD_FLAG=
NEXT_PUBLIC_ONBOARD_CODE=

# Community calls (server-only)
# Required. Every /api/community-call/* route proxies to curator-backend, which also
# owns calls, recordings, and RSVPs. There's deliberately no fallback — an unset value
# throws rather than silently drifting. Point local dev at the same shared deploy prod
# uses, so data created in one environment is visible in the others.
CURATOR_BACKEND_URL=https://curator-api-staging-testnet.up.railway.app
# Optional. Transcripts come from rapporteur, a separate service; defaults to the shared
# staging deploy. Only set this to test against a different one.
# RAPPORTEUR_BACKEND_URL=

# Sentry (optional)
# NEXT_PUBLIC_APP_ENV=                    # Deployment environment (default: "development")
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=                             # All 3 required together for source maps
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Analytics (optional)
# NEXT_PUBLIC_AMPLITUDE_API_KEY=87bc6bb6653d7ba096c25a1330dd83a
# NEXT_PUBLIC_POSTHOG_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://v.geobrowser.io

# X Ads pixel (optional)
# NEXT_PUBLIC_X_PIXEL_ID=

# Features (optional)
# NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_GEO_CHAT_API_BASE_URL=http://localhost:8080

# Build (optional)
# DISABLE_REACT_COMPILER=1
# DISABLE_SENTRY=1

# Dev (optional)
# NEXT_PUBLIC_ENGINE_LOGGING=0            # Set to 0 to suppress
# NEXT_PUBLIC_STORE_LOGGING=0             # Set to 0 to suppress
