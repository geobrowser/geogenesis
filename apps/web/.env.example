# SENTRY_ORG=                             # All 3 required together for source maps
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Features (optional)
# NEXT_PUBLIC_MAPBOX_TOKEN=

# Build (optional)
# DISABLE_REACT_COMPILER=1
# DISABLE_SENTRY=1

# Dev (optional)
# NEXT_PUBLIC_ENGINE_LOGGING=0            # Set to 0 to suppress
# NEXT_PUBLIC_STORE_LOGGING=0             # Set to 0 to suppress
